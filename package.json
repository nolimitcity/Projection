{
  "name": "projection-mvp-api",
  "version": "0.1.0",
  "private": true,
  "description": "Projection MVP API bootstrap for project template and copy-settings flows.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
